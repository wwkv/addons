{
  "name": "familiebudget-desktop",
  "version": "1.0.16",
  "description": "FamilieBudget – persoonlijk budgetbeheer als desktop app",
  "main": "electron/main.js",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/wwkv/addons.git"
  },
  "scripts": {
    "electron:start": "electron .",
    "electron:build:win": "electron-builder --win --publish never",
    "electron:build:mac": "electron-builder --mac --publish never",
    "electron:build:linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "be.ward.familiebudget",
    "productName": "FamilieBudget",
    "copyright": "Copyright © 2026",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/*.node"
    ],
    "files": [
      "electron/**/*",
      "backend/**/*",
      "!backend/data/**",
      "!backend/node_modules/**"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "electron/assets/icon.ico"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "electron/assets/icon.icns",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}
